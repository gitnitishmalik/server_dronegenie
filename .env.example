# DroneGenie server environment variables
# Copy to `.env` and fill in real values. `.env` is gitignored.

# --- runtime ---
ENV=development                # development | production
DEV_PORT=4020
PROD_PORT=3000
FRONTEND_URL=http://localhost:5173

# --- CORS ---
# Comma-separated list of extra origins to allow.
ALLOWED_ORIGINS=https://drone-genie-phi.vercel.app,https://another-domain.com

# --- database ---
# MongoDB connection string used by Prisma (see prisma/schema.prisma).
DATABASE_URL=mongodb://user:password@host:27017/dronegenie?replicaSet=rs0&authSource=admin

# --- auth ---
AT_SECRET=replace-with-long-random-string
RT_SECRET=replace-with-long-random-string
FORGOT_SECRET=replace-with-long-random-string

# --- email (Gmail SMTP via app password) ---
GMAIL_USER=ops@example.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- SMS ---
FAST_TO_SMS_API_KEY=

# --- payments (Razorpay) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- swagger (basic-auth gate on /api/docs) ---
SWAGGER_USER=admin
SWAGGER_PASSWORD=change-me

# --- Claude (service-tier AI features) ---
ANTHROPIC_API_KEY=
DAILY_CLAUDE_BUDGET_USD=5

# --- feature flags ---
PAYMENTS_V2_ENABLED=false

# --- puppeteer ---
# Chrome-for-Testing has no aarch64 build, so on ARM64 hosts the puppeteer
# bundled binary is x86-64 and fails with ENOEXEC. On aarch64 (e.g. OCI
# Ampere VMs running OL9), install `chromium-headless` from EPEL and point
# this at the system binary:
#   PUPPETEER_EXECUTABLE_PATH=/usr/lib64/chromium-browser/headless_shell
# On x86-64 dev machines, leave unset to use the puppeteer-bundled Chrome.
PUPPETEER_EXECUTABLE_PATH=
